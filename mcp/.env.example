# --- Nginx Proxy Manager connection ---
# Base URL of the NPM API. This is the admin interface host with the /api suffix.
# Typically the admin UI runs on port 81, so the API base is http://host:81/api
NPM_BASE_URL=http://localhost:81/api

# Recommended: an NPM API key, created in the NPM UI under "API Keys".
# Works for accounts with two-factor auth and can be revoked/rerolled at any
# time. When set, NPM_IDENTITY/NPM_SECRET are ignored.
NPM_API_KEY=

# Fallback: credentials for an NPM user WITHOUT two-factor auth enabled.
# The server logs in with these and auto-refreshes the JWT.
NPM_IDENTITY=admin@example.com
NPM_SECRET=changeme

# --- MCP HTTP server ---
# Port the Streamable HTTP MCP endpoint listens on.
MCP_PORT=3001

# Host/interface to bind. Use 127.0.0.1 to keep it local-only.
MCP_HOST=127.0.0.1

# Optional. If set, MCP clients must send `Authorization: Bearer <token>`
# to reach the /mcp endpoint. Leave empty to disable auth (local use only).
MCP_AUTH_TOKEN=

# Optional. Reject NPM TLS certs that don't validate (set to "false" to allow
# self-signed certs when NPM_BASE_URL is https). Default: true.
NPM_TLS_REJECT_UNAUTHORIZED=true
