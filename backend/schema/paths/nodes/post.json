{
	"operationId": "createNode",
	"summary": "Create Node",
	"tags": ["nodes"],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"requestBody": {
		"description": "Node payload",
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"additionalProperties": false,
					"required": ["name"],
					"properties": {
						"name": { "type": "string", "minLength": 1, "example": "Edge Node 1" }
					}
				},
				"example": { "name": "Edge Node 1" }
			}
		}
	},
	"responses": {
		"201": {
			"description": "Created node with one-time enrollment token (token is only returned here)",
			"content": {
				"application/json": {
					"schema": {
						"type": "object",
						"properties": {
							"id": { "type": "integer" },
							"created_on": { "type": "string", "format": "date-time" },
							"modified_on": { "type": "string", "format": "date-time" },
							"name": { "type": "string" },
							"status": { "type": "string", "enum": ["pending", "online", "offline"] },
							"connected": { "type": "boolean" },
							"meta": { "type": "object" },
							"token": { "type": "string", "description": "One-time enrollment token — only returned on creation" },
							"setup_command": { "type": "string", "description": "Docker command to enroll the node" }
						}
					},
					"example": {
						"id": 1,
						"created_on": "2026-07-01T00:00:00.000Z",
						"modified_on": "2026-07-01T00:00:00.000Z",
						"name": "Edge Node 1",
						"status": "pending",
						"connected": false,
						"meta": {},
						"token": "npma_abcdef1234567890abcdef1234567890abcdef1234567890",
						"setup_command": "docker run -d --name npm-agent ..."
					}
				}
			}
		}
	}
}
