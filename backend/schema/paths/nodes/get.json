{
	"operationId": "getNodes",
	"summary": "List Nodes",
	"tags": ["nodes"],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"responses": {
		"200": {
			"description": "List of nodes",
			"content": {
				"application/json": {
					"schema": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"id": { "type": "integer" },
								"created_on": { "type": "string", "format": "date-time" },
								"modified_on": { "type": "string", "format": "date-time" },
								"name": { "type": "string" },
								"status": { "type": "string", "enum": ["pending", "online", "offline"] },
								"connected": { "type": "boolean" },
								"meta": { "type": "object" }
							}
						}
					},
					"example": [
						{
							"id": 1,
							"created_on": "2026-07-01T00:00:00.000Z",
							"modified_on": "2026-07-01T00:00:00.000Z",
							"name": "Edge Node 1",
							"status": "online",
							"connected": true,
							"meta": {}
						}
					]
				}
			}
		}
	}
}
