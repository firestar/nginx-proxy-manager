{
	"operationId": "getNotificationChannels",
	"summary": "List Notification Channels",
	"tags": ["notifications"],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"responses": {
		"200": {
			"description": "List of notification channels",
			"content": {
				"application/json": {
					"schema": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"id": { "type": "integer" },
								"created_on": { "type": "string", "format": "date-time" },
								"modified_on": { "type": "string", "format": "date-time" },
								"name": { "type": "string" },
								"type": { "type": "string", "enum": ["webhook", "slack", "discord", "telegram", "email"] },
								"config": { "type": "object" },
								"events": { "type": "array", "items": { "type": "string" } },
								"enabled": { "type": "boolean" }
							}
						}
					},
					"example": [
						{
							"id": 1,
							"created_on": "2026-07-01T00:00:00.000Z",
							"modified_on": "2026-07-01T00:00:00.000Z",
							"name": "My Webhook",
							"type": "webhook",
							"config": { "url": "https://example.com/hook" },
							"events": ["host_offline", "host_online"],
							"enabled": true
						}
					]
				}
			}
		}
	}
}
