{
	"operationId": "reportsNodesMetrics",
	"summary": "Get Per-Node Metrics",
	"tags": ["reports"],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"responses": {
		"200": {
			"description": "Per-node request rate (last 15 min) and last metric bucket",
			"content": {
				"application/json": {
					"schema": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"nodeId": { "type": "integer" },
								"requestsLast15m": { "type": "integer", "description": "Total requests in the last 15 minutes" },
								"lastMetricBucket": { "type": "string", "nullable": true, "description": "Timestamp of the most recent metric bucket received" }
							}
						}
					},
					"example": [
						{
							"nodeId": 1,
							"requestsLast15m": 1240,
							"lastMetricBucket": "2026-07-12 09:59:00"
						}
					]
				}
			}
		}
	}
}
