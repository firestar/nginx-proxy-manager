{
	"operationId": "createApiKey",
	"summary": "Create a new API key",
	"description": "The response includes the full secret key exactly once. It cannot be retrieved again.",
	"tags": ["api-keys"],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"requestBody": {
		"description": "API Key Payload",
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"additionalProperties": false,
					"required": ["name"],
					"type": "object",
					"properties": {
						"name": {
							"type": "string",
							"minLength": 1,
							"maxLength": 100,
							"example": "MCP Server"
						}
					}
				},
				"example": {
					"name": "MCP Server"
				}
			}
		}
	},
	"responses": {
		"201": {
			"description": "201 response",
			"content": {
				"application/json": {
					"examples": {
						"default": {
							"value": {
								"id": 1,
								"created_on": "2026-07-11T12:00:00.000Z",
								"modified_on": "2026-07-11T12:00:00.000Z",
								"user_id": 1,
								"name": "MCP Server",
								"last_used_on": null,
								"key": "npm_yE5rE9Yo0nOFrknW9DBB1WNMdiTBAWyC8IFB1BLzUwM"
							}
						}
					},
					"schema": {
						"$ref": "../../components/api-key-object.json"
					}
				}
			}
		}
	}
}
