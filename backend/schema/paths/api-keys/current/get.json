{
	"operationId": "getCurrentApiKey",
	"summary": "Introspect the API key used for this request",
	"description": "Returns the key row (never the secret) including its scopes. Only valid when the request is authenticated with an API key; other tokens get a 403.",
	"tags": ["api-keys"],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"responses": {
		"200": {
			"description": "200 response",
			"content": {
				"application/json": {
					"examples": {
						"default": {
							"value": {
								"id": 1,
								"created_on": "2026-07-11T12:00:00.000Z",
								"modified_on": "2026-07-11T12:00:00.000Z",
								"user_id": 1,
								"name": "MCP Server",
								"scopes": ["proxy_hosts:manage", "certificates:view"],
								"last_used_on": "2026-07-11T12:00:00.000Z"
							}
						}
					},
					"schema": {
						"$ref": "../../../components/api-key-object.json"
					}
				}
			}
		}
	}
}
