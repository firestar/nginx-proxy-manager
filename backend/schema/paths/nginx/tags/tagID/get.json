{
	"operationId": "getTag",
	"summary": "Get a Tag",
	"tags": ["tags"],
	"security": [
		{
			"bearerAuth": ["tags.view"]
		}
	],
	"parameters": [
		{
			"in": "path",
			"name": "tagID",
			"description": "Tag ID",
			"schema": {
				"type": "integer",
				"minimum": 1
			},
			"required": true,
			"example": 1
		}
	],
	"responses": {
		"200": {
			"description": "200 response",
			"content": {
				"application/json": {
					"example": {
						"id": 1,
						"created_on": "2026-07-01T00:00:00.000Z",
						"modified_on": "2026-07-01T00:00:00.000Z",
						"owner_user_id": 1,
						"name": "Production",
						"color": "#206bc4",
						"meta": {}
					},
					"schema": {
						"$ref": "../../../../components/tag-object.json"
					}
				}
			}
		}
	}
}
