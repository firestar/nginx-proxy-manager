{
	"operationId": "updateTag",
	"summary": "Update a Tag",
	"tags": ["tags"],
	"security": [
		{
			"bearerAuth": ["tags.manage"]
		}
	],
	"parameters": [
		{
			"in": "path",
			"name": "tagID",
			"description": "Tag ID",
			"schema": {
				"type": "integer",
				"minimum": 1
			},
			"required": true,
			"example": 1
		}
	],
	"requestBody": {
		"description": "Tag Payload",
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"additionalProperties": false,
					"minProperties": 1,
					"properties": {
						"name": {
							"$ref": "../../../../components/tag-object.json#/properties/name"
						},
						"color": {
							"$ref": "../../../../components/tag-object.json#/properties/color"
						},
						"icon": {
							"$ref": "../../../../components/tag-object.json#/properties/icon"
						},
						"meta": {
							"$ref": "../../../../components/tag-object.json#/properties/meta"
						}
					}
				},
				"example": {
					"name": "Staging",
					"color": "#f59f00"
				}
			}
		}
	},
	"responses": {
		"200": {
			"description": "200 response",
			"content": {
				"application/json": {
					"example": {
						"id": 1,
						"created_on": "2026-07-01T00:00:00.000Z",
						"modified_on": "2026-07-01T00:00:00.000Z",
						"owner_user_id": 1,
						"name": "Staging",
						"color": "#f59f00",
						"icon": "flask",
						"meta": {}
					},
					"schema": {
						"$ref": "../../../../components/tag-object.json"
					}
				}
			}
		}
	}
}
