{
	"operationId": "createTag",
	"summary": "Create a Tag",
	"tags": ["tags"],
	"security": [
		{
			"bearerAuth": ["tags.manage"]
		}
	],
	"requestBody": {
		"description": "Tag Payload",
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"additionalProperties": false,
					"required": ["name"],
					"properties": {
						"name": {
							"$ref": "../../../components/tag-object.json#/properties/name"
						},
						"color": {
							"$ref": "../../../components/tag-object.json#/properties/color"
						},
						"meta": {
							"$ref": "../../../components/tag-object.json#/properties/meta"
						}
					}
				},
				"example": {
					"name": "Production",
					"color": "#206bc4"
				}
			}
		}
	},
	"responses": {
		"201": {
			"description": "201 response",
			"content": {
				"application/json": {
					"example": {
						"id": 1,
						"created_on": "2026-07-01T00:00:00.000Z",
						"modified_on": "2026-07-01T00:00:00.000Z",
						"owner_user_id": 1,
						"name": "Production",
						"color": "#206bc4",
						"meta": {}
					},
					"schema": {
						"$ref": "../../../components/tag-object.json"
					}
				}
			}
		}
	}
}
