{
	"operationId": "getProxyHostMaintenancePage",
	"summary": "Get the custom maintenance page HTML for a Proxy Host",
	"tags": ["proxy-hosts"],
	"security": [
		{
			"bearerAuth": ["proxy_hosts.manage"]
		}
	],
	"parameters": [
		{
			"in": "path",
			"name": "hostID",
			"description": "The ID of the Proxy Host",
			"schema": {
				"type": "integer",
				"minimum": 1
			},
			"required": true,
			"example": 2
		}
	],
	"responses": {
		"200": {
			"description": "200 response",
			"content": {
				"application/json": {
					"schema": {
						"type": "object",
						"properties": {
							"html": {
								"type": "string",
								"description": "Custom HTML content; empty string means the built-in branded page is used"
							}
						}
					}
				}
			}
		}
	}
}
